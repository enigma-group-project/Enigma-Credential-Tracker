{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Credential (off-chain record.json) — Enigma-Credential-Tracker",
  "type": "object",
  "required": ["credentialId", "program", "institution", "documentCid", "owner"],
  "properties": {
    "credentialId": { "type": "string", "description": "natural key; hashed to the on-chain id" },
    "program":      { "type": "string", "description": "degree / certificate name" },
    "institution":  { "type": "string" },
    "documentCid":  { "type": "string", "description": "IPFS CID of the diploma PDF" },
    "owner":        { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "issuedDate":   { "type": "string", "format": "date" },
    "grade":        { "type": "string" }
  }
}
